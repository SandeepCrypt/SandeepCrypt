# ============================================
# INTERVIEWMATE AI - ENVIRONMENT VARIABLES
# ============================================

# Flask
FLASK_ENV=development
SECRET_KEY=your-super-secret-key-change-in-production
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production

# Database
DATABASE_URL=mysql+pymysql://root:password@localhost/interviewmate_db
MONGO_URI=mongodb://localhost:27017/interviewmate_mongo

# Email
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=noreply@interviewmate-ai.com

# AI Services
OPENAI_API_KEY=your-openai-api-key
HUGGINGFACE_API_KEY=your-huggingface-api-key

# File Upload
MAX_CONTENT_LENGTH=16777216

# Logging
LOG_LEVEL=INFO
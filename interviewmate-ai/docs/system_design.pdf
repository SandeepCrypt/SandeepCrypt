\section{API Design}

\subsection{Authentication Endpoints}
\begin{longtable}{@{}p{2.5cm}p{2cm}p{8cm}@{}}
\toprule
\textbf{Endpoint} & \textbf{Method} & \textbf{Description} \\
\midrule
/api/auth/register & POST & Create new user account \\
/api/auth/login & POST & Authenticate and return JWT tokens \\
/api/auth/refresh & POST & Refresh access token using refresh token \\
/api/auth/forgot-password & POST & Send password reset email \\
/api/auth/reset-password & POST & Reset password with OTP verification \\
\bottomrule
\end{longtable}

\subsection{Interview Endpoints}
\begin{longtable}{@{}p{3.5cm}p{2cm}p{7cm}@{}}
\toprule
\textbf{Endpoint} & \textbf{Method} & \textbf{Description} \\
\midrule
/api/interview/start & POST & Initialize new interview session \\
/api/interview/question & GET & Fetch next question \\
/api/interview/submit & POST & Submit audio/video response \\
/api/interview/analyze & POST & Trigger AI analysis on response \\
/api/interview/end & POST & Complete session and generate report \\
\bottomrule
\end{longtable}

\section{Security Design}
\begin{itemize}
    \item \textbf{Authentication:} JWT with RS256 signing, 15-min access token, 7-day refresh token
    \item \textbf{Authorization:} Role-based access control (RBAC) with decorators
    \item \textbf{Input Validation:} Pydantic models for all API inputs
    \item \textbf{File Upload:} MIME type validation, size limits, virus scanning (ClamAV)
    \item \textbf{CORS:} Whitelist-based cross-origin policy
\end{itemize}

\section{Scalability Considerations}
\begin{itemize}
    \item AI modules can be containerized and scaled horizontally
    \item Redis caching for frequently accessed questions and user profiles
    \item CDN for static assets and company logos
    \item Database read replicas for report generation queries
\end{itemize}


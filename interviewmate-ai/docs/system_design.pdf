\section{Component Design}

\subsection{Frontend Components}
\begin{longtable}{@{}p{3.5cm}p{9cm}@{}}
\toprule
\textbf{Component} & \textbf{Responsibility} \\
\midrule
AuthContext & Global authentication state, JWT management, token refresh \\
InterviewContext & Interview session state, question queue, timer management \\
useWebcam & Custom hook for webcam access, frame capture, cleanup \\
useAudioRecorder & Custom hook for MediaRecorder API, audio blob management \\
VideoFeed & Displays webcam stream with emotion overlay canvas \\
QuestionDisplay & Renders current question with timer and progress bar \\
RealtimeFeedback & Shows live tips based on emotion analysis results \\
EmotionVisualizer & Charts for facial/speech emotion timeline \\
\bottomrule
\end{longtable}

\subsection{Backend Services}
\begin{longtable}{@{}p{3.5cm}p{9cm}@{}}
\toprule
\textbf{Service} & \textbf{Responsibility} \\
\midrule
Auth Service & Registration, login, JWT issuance, password reset \\
Interview Service & Session lifecycle, question delivery, response collection \\
Question Generator & LLM prompt engineering, resume parsing, question customization \\
Face Emotion Detector & Frame preprocessing, CNN inference, emotion label mapping \\
Speech Emotion Detector & Audio feature extraction (MFCC, chroma, mel spectrogram), ML classification \\
NLP Analyzer & Transcript analysis, grammar checking, STAR compliance, keyword matching \\
Confidence Scorer & Weighted aggregation of all factor scores \\
Report Generator & Chart generation, PDF compilation, improvement tip generation \\
\bottomrule
\end{longtable}

\section{Data Flow Diagrams}

\subsection{Interview Session Flow}
\begin{enumerate}
    \item User selects category, company, uploads resume
    \item Backend parses resume $\rightarrow$ extracts skills/experience
    \item Question Generator creates personalized question set
    \item Frontend initializes WebRTC (video + audio)
    \item Every 500ms: Video frame $\rightarrow$ Face Emotion API $\rightarrow$ Score
    \item Every 2s: Audio chunk $\rightarrow$ Speech Emotion API $\rightarrow$ Score
    \item On answer completion: Audio $\rightarrow$ STT $\rightarrow$ NLP Analysis $\rightarrow$ Scores
    \item Session end: Aggregate all scores $\rightarrow$ Confidence Report $\rightarrow$ PDF
\end{enumerate}

